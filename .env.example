# ============================================================
# ENVIRONMENT VARIABLES - CONFIGURATION FILE
# ============================================================
# HOW TO USE:
#   1. Copy this file and rename it to ".env"
#   2. Replace "your_api_key_here" with your actual Anthropic API key
#   3. Get your API key from: https://console.anthropic.com
#
# IMPORTANT: Never share your .env file or push it to GitHub!
# ============================================================

ANTHROPIC_API_KEY=your_api_key_here
